# =============================================================================
# Recon Platform — Environment Variables
# This file is for LOCAL DEVELOPMENT only.
# In production (Docker Swarm / Portainer), inject ALL variables via the stack
# environment — do NOT copy this file to the Pi. Secrets (tokens, API keys)
# must be set directly in Portainer's stack environment UI, not in a .env file.
# =============================================================================

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Storage -----------------------------------------------------------------
SQLITE_PATH=/data/db/recon.db
OUTPUT_DIR=/data/output

# --- Ingestor ----------------------------------------------------------------
INGESTOR_PORT=8090

# --- Scan intervals (hours) --------------------------------------------------
DEFAULT_RECON_INTERVAL_HOURS=24
DEFAULT_HTTPX_INTERVAL_HOURS=12
DEFAULT_NUCLEI_INTERVAL_HOURS=24

# --- Concurrency (keep low on Pi 5 to avoid rate-limit / OOM) ---------------
MAX_RECON_CONCURRENCY=2
MAX_HTTPX_CONCURRENCY=10
MAX_NUCLEI_CONCURRENCY=1

# --- Nuclei ------------------------------------------------------------------
NUCLEI_TEMPLATES_DIR=/templates
NUCLEI_TEMPLATES_UPDATE_INTERVAL_HOURS=24
# Minimum severity to create a finding / trigger a notification.
# Values: info | low | medium | high | critical
NUCLEI_SEVERITY_MIN=high
# Seconds to wait between successive nuclei scans against the same scope_root.
# Prevents hammering a single target with back-to-back scans.
NUCLEI_THROTTLE_SECS=30

# --- Notifications -----------------------------------------------------------
# Leave blank to disable a channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DISCORD_WEBHOOK_URL=

# --- Active recon (DNS brute-force) ------------------------------------------
# Threads and retries for shuffledns
DNS_BRUTE_THREADS=20
DNS_BRUTE_RETRIES=3
# Hard cap on permutation candidates before resolving
MAX_PERMUTATION_CANDIDATES=50000
# Subprocess timeouts (seconds)
DNS_TIMEOUT_SECS=900
PERM_TIMEOUT_SECS=600

# --- Passive recon provider API keys (all optional) -------------------------
# Adding keys significantly improves subdomain coverage.
SUBFINDER_SHODAN_API_KEY=
SUBFINDER_CENSYS_API_ID=
SUBFINDER_CENSYS_API_SECRET=
SUBFINDER_SECURITYTRAILS_API_KEY=
SUBFINDER_VIRUSTOTAL_API_KEY=
AMASS_SHODAN_API_KEY=
